{
  "name": "kite-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Kite desktop shell",
  "main": "main.cjs",
  "scripts": {
    "package:mac": "electron-builder --mac dmg",
    "package:mac:arm64": "electron-builder --mac dmg --arm64",
    "package:mac:x64": "electron-builder --mac dmg --x64",
    "package:win:x64": "electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "dev.kite.desktop",
    "productName": "Kite",
    "asar": true,
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "extraResources": [
        {
          "from": "build/icon.png",
          "to": "icon.png"
        },
        {
          "from": "resources/kite",
          "to": "kite"
        }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "resources/kite.exe",
          "to": "kite.exe"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "dist"
    }
  }
}
